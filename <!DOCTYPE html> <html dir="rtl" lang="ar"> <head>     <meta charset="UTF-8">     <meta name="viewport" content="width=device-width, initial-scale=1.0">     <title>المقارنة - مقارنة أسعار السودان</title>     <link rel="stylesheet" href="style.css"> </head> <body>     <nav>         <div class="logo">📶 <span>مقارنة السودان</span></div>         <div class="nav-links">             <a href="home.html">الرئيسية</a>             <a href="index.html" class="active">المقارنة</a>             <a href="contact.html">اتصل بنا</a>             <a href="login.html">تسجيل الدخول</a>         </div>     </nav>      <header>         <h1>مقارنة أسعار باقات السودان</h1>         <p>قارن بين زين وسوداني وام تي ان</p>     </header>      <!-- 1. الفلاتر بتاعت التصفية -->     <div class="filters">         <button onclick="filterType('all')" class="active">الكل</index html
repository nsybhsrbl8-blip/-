<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المقارنة - مقارنة أسعار السودان</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav>
        <div class="logo">📶 <span>مقارنة السودان</span></div>
        <div class="nav-links">
            <a href="home.html">الرئيسية</a>
            <a href="index.html" class="active">المقارنة</a>
            <a href="contact.html">اتصل بنا</a>
            <a href="login.html">تسجيل الدخول</a>
        </div>
    </nav>

    <header>
        <h1>مقارنة أسعار باقات السودان</h1>
        <p>قارن بين زين وسوداني وام تي ان</p>
    </header>

    <!-- 1. الفلاتر بتاعت التصفية -->
    <div class="filters">
        <button onclick="filterType('all')" class="active">الكل</button>
        <button onclick="filterType('انترنت')">انترنت</button>
        <button onclick="filterType('مكالمات')">مكالمات</button>
        
        <select id="companyFilter" onchange="filterCompany()">
            <option value="all">كل الشركات</option>
            <option value="زين">زين</option>
            <option value="سوداني">سوداني</option>
            <option value="ام تي ان">ام تي ان</option>
        </select>
    </div>

    <!-- 2. هنا مكان الباقات - ده المهم -->
    <div class="grid" id="packagesGrid">
        <!-- script.js ح يملا المكان ده تلقائي -->
    </div>

    <footer>
        <p>© 2026 موقع مقارنة الاسعار في السودان</p>
    </footer>

    <!-- 3. لازم سكريبت الجافا يكون اخر شي -->
    <script src="script.js"></script>
</body>
</htm
